{
  "name": "rn-template",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:cc": "expo start --clear",
    "dev:off": "expo start --offline",
    "build:web": "expo export --platform web",
    "view": "expo serve",
    "lint": "biome check --fix src",
    "test": "jest",
    "check": "expo-doctor",
    "prepare": "lefthook install",
    "update": "nlx expo@latest install --fix && ncu -u && ni",
    "commit": "git add -A && git commit --no-edit",
    "squash": "bun scripts/squash.ts && git commit --no-edit --no-verify"
  },
  "dependencies": {
    "expo": "~55.0.2",
    "expo-constants": "^55.0.7",
    "expo-linking": "^55.0.7",
    "expo-router": "~55.0.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@es-proj/utils": "^1.6.7",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "czg": "^1.12.0",
    "expo-doctor": "^1.18.8",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "knip": "^5.85.0",
    "lefthook": "^2.1.1",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  }
}
