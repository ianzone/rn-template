{
  "name": "rn-template",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:cc": "expo start --clear",
    "dev:off": "expo start --offline",
    "build:web": "expo export --platform web",
    "view": "expo serve",
    "lint": "biome check --fix src",
    "test": "jest",
    "check": "expo-doctor",
    "prepare": "lefthook install",
    "update": "nup expo@latest && expo install --fix && ncu -u && ni",
    "commit": "git add -A && git commit --no-edit",
    "squash": "bun scripts/squash.ts && git commit --no-edit --no-verify"
  },
  "dependencies": {
    "expo": "~54.0.31",
    "expo-constants": "^18.0.13",
    "expo-linking": "^8.0.11",
    "expo-router": "~6.0.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@es-proj/utils": "^1.6.7",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "czg": "^1.12.0",
    "expo-doctor": "^1.17.14",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.16",
    "knip": "^5.81.0",
    "lefthook": "^2.0.15",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  }
}
